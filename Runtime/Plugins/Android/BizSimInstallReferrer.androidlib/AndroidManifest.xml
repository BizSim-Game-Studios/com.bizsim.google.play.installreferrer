<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- C5.2 predictive back gesture (Android 14+ / API 34+).
         InstallReferrer has NO UI surface — it's a pure API call that returns
         cached referrer data via local IPC to Google Play. Opt-out explicitly
         declared so consumer apps merging manifests see the intent. Per
         2026-04-17-enterprise-quality-bar 06-conventions/05-predictive-back-audit.md.
         Consumer app-level android:enableOnBackInvokedCallback wins on
         manifest-merger conflict. -->
    <application
        android:enableOnBackInvokedCallback="false"
        tools:targetApi="33" />

</manifest>
