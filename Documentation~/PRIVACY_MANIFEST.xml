<?xml version="1.0" encoding="UTF-8"?>
<!--
  Privacy Manifest for Google Play Install Referrer Bridge
  Package: com.bizsim.google.play.installreferrer

  This manifest declares the data practices of this package.
  Android-only package for Google Play Install Referrer API.

  Reference:
  - Google Play Data Safety: https://support.google.com/googleplay/android-developer/answer/10787469
-->
<privacy-manifest>
  <data-collection>
    <!-- Referrer URL: collected from Google Play Install Referrer API, cached locally -->
    <data-type category="app-activity" subcategory="app-interactions">
      <collected>true</collected>
      <shared>false</shared>
      <ephemeral>false</ephemeral>
      <required>false</required>
      <retention-period>90-days</retention-period>
      <purpose>analytics</purpose>
      <description>
        Install referrer URL and UTM parameters retrieved from Google Play
        Install Referrer API for install attribution tracking. Cached locally
        in PlayerPrefs with 90-day TTL. Can be cleared via SetConsentGranted(false).
      </description>
    </data-type>

    <!-- Install timestamps: collected from Google Play Install Referrer API -->
    <data-type category="app-activity" subcategory="app-interactions">
      <collected>true</collected>
      <shared>false</shared>
      <ephemeral>false</ephemeral>
      <required>false</required>
      <retention-period>90-days</retention-period>
      <purpose>analytics</purpose>
      <description>
        Install begin and click timestamps for attribution timing.
        Cached locally with referrer data. No external transmission.
      </description>
    </data-type>

    <!-- Analytics event (optional, requires analytics adapter injection) -->
    <data-type category="app-activity" subcategory="app-interactions" optional="true">
      <collected>true</collected>
      <shared>true</shared>
      <shared-with>per-adapter-implementation</shared-with>
      <ephemeral>false</ephemeral>
      <required>false</required>
      <purpose>analytics</purpose>
      <description>
        UTM source, medium, campaign, and organic flag logged via injected
        analytics adapter. Only active when an IInstallReferrerAnalyticsAdapter
        is provided. Minimal logging mode available via LogReferrerFetchedMinimal().
      </description>
    </data-type>
  </data-collection>

  <network-requests>
    <api name="Google Play Install Referrer API">
      <initiated-by>google-play-services-sdk</initiated-by>
      <frequency>once-per-install</frequency>
      <data-transmitted>none (local IPC via AIDL binding)</data-transmitted>
    </api>
  </network-requests>
</privacy-manifest>
